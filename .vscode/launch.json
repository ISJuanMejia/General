{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "QueryGenerator.Api (.NET)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/Tools/QueryGenerator.Api/bin/Debug/net8.0/QueryGenerator.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Tools/QueryGenerator.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "QueryGenerator.App (Angular)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/Tools/QueryGenerator.App",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "start"
            ],
            "port": 4200
        }
    ],
    "compounds": [
        {
            "name": "Run Full Application",
            "configurations": [
                "QueryGenerator.Api (.NET)",
                "QueryGenerator.App (Angular)"
            ]
        }
    ]
}
