{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-api",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Tools/QueryGenerator.Api/QueryGenerator.Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "npm-install-app",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/Tools/QueryGenerator.App"
            }
        },
        {
            "label": "Run Application",
            "dependsOn": ["build-api", "npm-install-app"],
            "type": "shell",
            "command": "echo 'Preparación completada. Use F5 para lanzar los proyectos.'"
        }
    ]
}
